{
  "manifest_version": 3,
  "name": "ProPost Assistant",
  "version": "1.0.0",
  "description": "Generate professional LinkedIn posts from Gmail achievements with AI.",
  "permissions": ["identity", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://www.linkedin.com/*",
    "https://api.anthropic.com/*",
    "https://newsapi.org/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "ProPost Assistant"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/content-script.js"]
    }
  ],
  "oauth2": {
    "client_id": "942003377429-u57j7fckcmabvedjt3smbgcpn4gvvi2f.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  }
}
